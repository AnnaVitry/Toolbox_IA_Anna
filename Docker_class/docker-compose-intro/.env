# --- PORTS HÔTES (Ta machine) ---
# Choisis des numéros différents pour CHAQUE variable ci-dessous
API_PORT=8000 # Vérifie en allant sur http://localhost:8000/docs
PHPMYADMIN_PORT=8081 # http://localhost:8081
APACHE_PORT=8082 # Ne se vra pas en Apache parce que pas de index.html
STREAMLIT_PORT=8501 # http://localhost:8501
MYSQL_PORT=3310

# --- CONFIG STACK ---
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=my_database
PMA_HOST=mysql_db # Doit correspondre au nom du service dans le yml